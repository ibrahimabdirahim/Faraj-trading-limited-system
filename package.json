{
  "name": "faraj-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx database/prisma/seed.ts",
    "db:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema=database/prisma/schema.prisma && tsx database/prisma/seed.ts",
    "setup": "prisma migrate deploy --schema=database/prisma/schema.prisma && prisma generate --schema=database/prisma/schema.prisma && tsx database/prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx database/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
